<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_shield"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Privacy Display"
                android:textColor="@color/colorWhite"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AMOLED Shoulder-Surf Protection"
            android:textColor="@color/colorGray"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- ── Permission Card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvPermissionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking permissions…"
                android:textColor="@color/colorYellow"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnRequestPermission"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Grant Permission"
                android:textSize="12sp"
                android:background="@drawable/btn_secondary"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ── Status Card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tvStatusDot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/colorGray"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INACTIVE"
                    android:textColor="@color/colorGray"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />
            </LinearLayout>

            <Button
                android:id="@+id/btnToggle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="ENABLE PRIVACY MODE"
                android:textColor="@color/colorWhite"
                android:textStyle="bold"
                android:textSize="15sp"
                android:background="@drawable/btn_primary"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/tvPrivacyEffect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~35–45% readability reduction from distance"
                android:textColor="@color/colorGrayLight"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- ── Controls ── -->
        <LinearLayout
            android:id="@+id/layoutControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Privacy Level -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Privacy Strength"
                        android:textColor="@color/colorWhite"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPrivacyLevelValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 2 — Medium"
                        android:textColor="@color/colorAccent"
                        android:textSize="13sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/sliderPrivacyLevel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50"
                    android:progressTint="@color/colorAccent"
                    android:thumbTint="@color/colorAccent" />
            </LinearLayout>

            <!-- Opacity -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Overlay Opacity"
                        android:textColor="@color/colorWhite"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvOpacityValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="60%"
                        android:textColor="@color/colorAccent"
                        android:textSize="13sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/sliderOpacity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="60"
                    android:progressTint="@color/colorAccent"
                    android:thumbTint="@color/colorAccent" />
            </LinearLayout>

            <!-- Pattern Size -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pattern Size"
                        android:textColor="@color/colorWhite"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPatternSizeValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5px"
                        android:textColor="@color/colorAccent"
                        android:textSize="13sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/sliderPatternSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="6"
                    android:progress="3"
                    android:progressTint="@color/colorAccent"
                    android:thumbTint="@color/colorAccent" />
            </LinearLayout>

            <!-- Pattern Type -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pattern Type"
                    android:textColor="@color/colorWhite"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/rgPatternType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbCheckerboard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checkerboard (Best privacy)"
                        android:textColor="@color/colorWhite"
                        android:buttonTint="@color/colorAccent"
                        android:checked="true"
                        android:layout_marginBottom="6dp" />

                    <RadioButton
                        android:id="@+id/rbHorizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Horizontal Stripes"
                        android:textColor="@color/colorWhite"
                        android:buttonTint="@color/colorAccent"
                        android:layout_marginBottom="6dp" />

                    <RadioButton
                        android:id="@+id/rbVertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vertical Stripes"
                        android:textColor="@color/colorWhite"
                        android:buttonTint="@color/colorAccent"
                        android:layout_marginBottom="6dp" />

                    <RadioButton
                        android:id="@+id/rbDots"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dot Matrix"
                        android:textColor="@color/colorWhite"
                        android:buttonTint="@color/colorAccent" />
                </RadioGroup>
            </LinearLayout>

            <!-- Toggles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Display Options"
                    android:textColor="@color/colorWhite"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Center Clarity -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Center Clarity Mode"
                            android:textColor="@color/colorWhite"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lighter overlay at screen center"
                            android:textColor="@color/colorGray"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchCenterClarity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="@color/colorAccent"
                        android:trackTint="@color/colorAccentDark" />
                </LinearLayout>

                <!-- AMOLED Mode -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AMOLED Battery Saver"
                            android:textColor="@color/colorWhite"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="True black pixels = zero power on AMOLED"
                            android:textColor="@color/colorGray"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchAmoledMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="@color/colorAccent"
                        android:trackTint="@color/colorAccentDark" />
                </LinearLayout>
            </LinearLayout>

            <!-- Tips Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_tip"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Tips"
                    android:textColor="@color/colorWhite"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Add Privacy tile to Quick Settings for fast toggle\n• Checkerboard works best for text privacy\n• Lower pattern size = stronger effect at distance\n• Enable Center Clarity for comfortable personal use\n• Works system-wide — overlays all apps"
                    android:textColor="@color/colorGrayLight"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
